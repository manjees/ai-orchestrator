# === Required ===
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USER_ID=123456789

# === Optional ===
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=deepseek-r1:latest
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
TMUX_SESSION_NAME=ai_factory
LOG_LEVEL=INFO
CMD_TIMEOUT=30
CMD_LONG_TIMEOUT=600
SOLVE_TIMEOUT=1800

# === Dual-Check Pipeline (legacy) ===
DUAL_CHECK_ENABLED=true
DEEPSEEK_DESIGN_TIMEOUT=600
DEEPSEEK_AUDIT_TIMEOUT=600

# === Five-brid Pipeline ===
# Set PIPELINE_MODE=fivebrid to enable the 9-step pipeline
# (overrides DUAL_CHECK_ENABLED when set to "fivebrid")
PIPELINE_MODE=legacy
GEMINI_MODEL=gemini-2.5-pro
HAIKU_MODEL=claude-haiku-4-5-20251001
OPUS_MODEL=claude-opus-4-6
SONNET_MODEL=claude-sonnet-4-6
RESEARCH_TIMEOUT=120
OPUS_DESIGN_TIMEOUT=900
GEMINI_CRITIQUE_TIMEOUT=600
MAX_DESIGN_RETRIES=2
SONNET_SELF_REVIEW_TIMEOUT=600
GEMINI_CROSS_REVIEW_TIMEOUT=600

# === Init Pipeline ===
PROJECTS_BASE_DIR=~/Desktop/dev
GITHUB_USER=your-github-username
DEFAULT_REPO_VISIBILITY=private
INIT_TIMEOUT=1800
INIT_EXEC_TIMEOUT=600
INIT_CI_WATCH_TIMEOUT=300
INIT_CI_FIX_RETRIES=2
INIT_ISSUE_PLANNING_TIMEOUT=900
